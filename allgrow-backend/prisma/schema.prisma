datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String        @id @default(uuid())
  name            String
  email           String        @unique
  password        String
  solvedQuestions Submissions[] @relation("UserSolved")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  scratchPads     ScratchPad[]  @relation("UserScratchPad")
}

model Questions {
  id              String        @id @default(uuid())
  title           String        @unique
  description     String
  input_format    String
  output_format   String
  sample_input    String
  sample_output   String
  test_cases      Json
  difficulty      String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  solvedQuestions Submissions[] @relation("QuestionSolved")
  scratchpad      ScratchPad[]  @relation("QuestionScratchPad")
}

model Submissions {
  id           String   @id @default(uuid())
  userId       String
  questionId   String
  languageId   Int
  scratchpadId String?
  code         String
  status       Status
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User        @relation("UserSolved", fields: [userId], references: [id])
  question   Questions   @relation("QuestionSolved", fields: [questionId], references: [id])
  scratchPad ScratchPad? @relation(fields: [scratchpadId], references: [id])
}

model ScratchPad {
  id             String   @id @default(uuid())
  userId         String
  questionId     String
  status         Status
  explanation    String
  aiSummary      String?
  aiSuggestions  String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user        User          @relation("UserScratchPad", fields: [userId], references: [id])
  question    Questions     @relation("QuestionScratchPad", fields: [questionId], references: [id])
  submissions Submissions[]
}

enum Status {
  accepted
  rejected
}
